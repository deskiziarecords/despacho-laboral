# ============================================
# Configuración del Despacho Laboral
# Copia este archivo como .env y ajusta valores
# ============================================

# --- Producción ---
# Genera un SECRET_KEY único con: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# SECRET_KEY=tu_secret_key_aqui

# DEBUG=false

# ALLOWED_HOSTS=.railway.app,tu-dominio.com
# CSRF_TRUSTED_ORIGINS=https://tu-app.railway.app

# --- Railway: Database ---
# Railway inyecta automáticamente PGHOST, PGUSER, PGPASSWORD, PGDATABASE, PGPORT
# No necesitas DATABASE_URL si agregas el addon de PostgreSQL en Railway
# También puedes usar DATABASE_URL directa:
# DATABASE_URL=postgres://user:password@host:5432/dbname

# --- Email (SMTP) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=tu-correo@gmail.com
# EMAIL_HOST_PASSWORD=tu-contrasena-de-app
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Despacho Laboral <noreply@despacho.com>

# ============================================
# Desarrollo local (valores por defecto)
# ============================================
# DEBUG=true
# DATABASE_URL=sqlite:///db.sqlite3
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
